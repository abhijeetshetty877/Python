SELECT
    c.customer_name,
    p.product_name
FROM Customers c
CROSS JOIN Products1 p;


---------------------------- multiple joins

-- Customers who have both Sales and Finance records.
select * from Personal_Details;
select * from Finance;
select * from Sales;



SELECT
    p.customer_id,
    p.customer_name,
    s.product_name,
    s.sale_amount,
    f.loan_amount
FROM Personal_Details p
INNER JOIN Sales s
    ON p.customer_id = s.customer_id
INNER JOIN Finance f
    ON p.customer_id = f.customer_id;


--- Show all customers even if they don't have sales or finance data.

SELECT
    p.customer_id,
    p.customer_name,
    s.product_name,
    f.loan_amount
FROM Personal_Details p
LEFT JOIN Sales s
    ON p.customer_id = s.customer_id
LEFT JOIN Finance f
    ON p.customer_id = f.customer_id;

--- Show all sales records even if customer details are missing.

SELECT
    p.customer_name,
    s.product_name,
    s.sale_amount
FROM Sales s
left JOIN Personal_Details p
    ON p.customer_id = s.customer_id;

