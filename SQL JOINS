----------- self joins - A SELF JOIN joins a table with itself.

-- In Personal_Details, each customer may have a referral customer.

SELECT
    c.customer_name AS Customer,
    r.customer_name AS Referred_By
FROM Personal_Details c
LEFT JOIN Personal_Details r
    ON c.referred_by = r.customer_id;


